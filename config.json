{
    "osc_server": {
        "listen_ip": "127.0.0.1",
        "listen_port": 53000
    },
    "flask_server": {
        "ip": "127.0.0.1",
        "port": 5009
    },
    "connections": [
        {
            "name": "HTTP to Cogs",
            "from": {
                "protocol": "http",
                "endpoint": "/send_osc"
            },
            "to": {
                "protocol": "osc",
                "ip": "192.168.50.226",
                "port": 12097
            }
        },
        {
            "name": "TCP to Cogs",
            "from": {
                "protocol": "tcp",
                "listen_ip": "127.0.0.1",
                "listen_port": 57676
            },
            "to": {
                "protocol": "osc",
                "ip": "127.0.0.1",
                "port": 12097
            }
        },
        {
            "name": "UDP to Cogs",
            "from": {
                "protocol": "udp",
                "listen_ip": "127.0.0.1",
                "listen_port": 57677
            },
            "to": {
                "protocol": "osc",
                "ip": "127.0.0.1",
                "port": 12097
            }
        },
        {
            "name": "OSC to TCP with values",
            "from": {
                "protocol": "osc",
                "address_pattern": "/game",
                "values": [
                    "GameID",
                    "Level"
                ]
            },
            "to": {
                "protocol": "tcp",
                "ip": "127.0.0.1",
                "port": 5001
            }
        },
        {
            "name": "OSC to HTTP with response",
            "from": {
                "protocol": "osc",
                "address_pattern": "/api_call"
            },
            "to": {
                "protocol": "http",
                "url": "https://httpbin.org/post"
            },
            "response_to_osc": {
                "enabled": true,
                "ip": "127.0.0.1",
                "port": 12097,
                "address": "/api_response"
            }
        },
        {
            "name": "Cogs to PC",
            "from": {
                "protocol": "osc",
                "name": "Cogs",
                "address_pattern": "/pc",
                "values": [
                    "command"
                ]
            },
            "to": {
                "protocol": "http",
                "name": "PC",
                "method": "GET",
                "url": "http://localhost:3000/api/command"
            }
        }
    ],
    "ignore_rules": [
        {
            "name": "Block heartbeat",
            "enabled": true,
            "log_matches": false,
            "condition_group": {
                "operator": "AND",
                "conditions": [
                    {
                        "type": "condition",
                        "field": "content.raw",
                        "op": "CONTAINS",
                        "value": "heartbeat"
                    }
                ]
            }
        }
    ],
    "file_logging": {
        "enabled": false,
        "retention_days": 7,
        "log_level": "DEBUG"
    }
}